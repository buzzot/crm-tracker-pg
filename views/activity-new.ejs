<div class="pnew-page">
  <a href="/companies/<%= company.id %>" class="pnew-back-link"><i class="bi bi-arrow-left"></i> <%= company.name %></a>

  <div class="pnew-badge"><i class="bi bi-activity"></i> New activity</div>
  <h1 class="pnew-hero">Log an <em>activity</em></h1>
  <p class="pnew-hero-sub">Record a call, meeting, email, or other touchpoint for <%= company.name %>.</p>

  <% if (error) { %>
    <div class="alert alert-danger mb-3"><%= error %></div>
  <% } %>

  <form action="/companies/<%= company.id %>/activities" method="POST">
    <div class="pnew-grid">

      <div class="pnew-main">

        <div class="pnew-card">
          <h2 class="pnew-card-title">Identity</h2>
          <p class="pnew-card-sub">What this activity is and when it happened.</p>

          <div class="mb-3">
            <label class="pnew-field-label" for="activityName">Activity name <span class="pnew-required">*</span></label>
            <input type="text" name="name" id="activityName" class="pnew-input" value="<%= values.name || '' %>" required autofocus placeholder="e.g. Intro call with CEO">
          </div>

          <div class="row g-3">
            <div class="col-md-6">
              <label class="pnew-field-label" for="activityType"><i class="bi bi-tag"></i> Type</label>
              <select name="type" id="activityType" class="pnew-select">
                <option value="">— Select —</option>
                <% typeChoices.forEach(opt => { %>
                  <option value="<%= opt %>" <%= values.type === opt ? 'selected' : '' %>><%= opt %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="pnew-field-label" for="activityDueDate"><i class="bi bi-calendar-check"></i> Complete before <span class="text-muted fw-normal">(optional)</span></label>
              <input type="date" name="dueDate" id="activityDueDate" class="pnew-input" value="<%= values.dueDate || '' %>">
            </div>
          </div>
        </div>

        <div class="pnew-card">
          <h2 class="pnew-card-title">People & projects</h2>
          <p class="pnew-card-sub">Who was involved and what project this relates to.</p>

          <div class="mb-3">
            <label class="pnew-field-label" for="activityAttendees"><i class="bi bi-people"></i> Attendees</label>
            <select name="attendeeIds" id="activityAttendees" class="pnew-select" multiple size="4">
              <% persons.forEach(p => { %>
                <option value="<%= p.id %>"><%= p.fullName %></option>
              <% }) %>
            </select>
            <p class="pnew-help mt-1">Hold Ctrl / Cmd to select more than one.</p>
          </div>

          <div class="mb-0">
            <label class="pnew-field-label" for="activityProjects"><i class="bi bi-kanban"></i> Related project(s)</label>
            <select name="projectIds" id="activityProjects" class="pnew-select" multiple size="4">
              <% projects.forEach(p => { %>
                <option value="<%= p.id %>"><%= p.name %></option>
              <% }) %>
            </select>
            <p class="pnew-help mt-1">Hold Ctrl / Cmd to select more than one.</p>
          </div>
        </div>

        <div class="pnew-card">
          <h2 class="pnew-card-title">Outcome</h2>
          <p class="pnew-card-sub">Result and any notes from this activity.</p>

          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label class="pnew-field-label" for="activityResult"><i class="bi bi-flag"></i> Result</label>
              <select name="result" id="activityResult" class="pnew-select">
                <option value="">— Select —</option>
                <% resultChoices.forEach(opt => { %>
                  <option value="<%= opt %>" <%= values.result === opt ? 'selected' : '' %>><%= opt %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="pnew-field-label" for="activityRegarding"><i class="bi bi-clock"></i> Regarding (date/time)</label>
              <input type="datetime-local" name="regarding" id="activityRegarding" class="pnew-input" value="<%= values.regarding || '' %>">
            </div>
          </div>

          <div class="mb-0">
            <label class="pnew-field-label" for="activityDetails"><i class="bi bi-card-text"></i> Details / notes</label>
            <textarea name="details" id="activityDetails" class="pnew-input pnew-textarea" rows="4" placeholder="Summary of what was discussed…"><%= values.details || '' %></textarea>
          </div>
        </div>

        <div class="d-flex gap-2">
          <button type="submit" class="pnew-btn-save"><i class="bi bi-check-lg"></i> Save activity</button>
          <a href="/companies/<%= company.id %>" class="pnew-btn-cancel">Cancel</a>
        </div>

      </div>

      <div class="pnew-aside">
        <div class="pnew-tip-card">
          <i class="bi bi-lightbulb"></i>
          <div class="pnew-tip-title">Activity types</div>
          <div class="pnew-tip-text">Use Call, Email, Meeting, Demo, or LinkedIn to categorise your touchpoints and filter them later in the Activity feed.</div>
        </div>
        <div class="pnew-tip-card">
          <i class="bi bi-kanban"></i>
          <div class="pnew-tip-title">Link a project</div>
          <div class="pnew-tip-text">Linking an activity to a project keeps the full history of client interactions visible from the project page.</div>
        </div>
      </div>

    </div>
  </form>
</div>
