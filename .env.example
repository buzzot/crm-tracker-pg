# ── Database (Supabase) ───────────────────────────────────────────────────────
# Get this from: Supabase dashboard → Settings → Database → Connection string
# Use "Transaction" mode (port 6543) for Railway, "Session" mode (port 5432) for direct
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DATABASE_SSL=true

# ── Supabase Storage (required for file/image uploads) ───────────────────────
# SUPABASE_URL:         Supabase dashboard → Settings → API → Project URL
# SUPABASE_SERVICE_KEY: Supabase dashboard → Settings → API → service_role key (secret)
# SUPABASE_BUCKET:      Storage bucket name (default: crm-files — only set if you renamed it)
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key...
# SUPABASE_BUCKET=crm-files

# ── Session ───────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SESSION_SECRET=change-this-to-a-long-random-string

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Email (Mailgun — inbound webhook + outbound sending) ─────────────────────
EMAIL_DOMAIN=mg.yourdomain.com
MAILGUN_WEBHOOK_KEY=your-mailgun-webhook-signing-key

# Outbound email (invitation emails, password reset, etc.)
# MAILGUN_API_KEY: Mailgun dashboard → API Keys → Private API key (key-…)
# MAILGUN_DOMAIN:  Your sending domain in Mailgun (usually same as EMAIL_DOMAIN)
# APP_URL:         Public base URL of the app — used for login links in emails
# LOGO_URL:        (optional) Public URL of Samyou logo image for email header
MAILGUN_API_KEY=key-your-mailgun-private-api-key
MAILGUN_DOMAIN=mg.yourdomain.com
APP_URL=https://your-crm-domain.com
# LOGO_URL=https://your-cdn.com/samyou-logo.png
