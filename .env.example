# ── Database (Supabase) ───────────────────────────────────────────────────────
# Get this from: Supabase dashboard → Settings → Database → Connection string
# Use "Transaction" mode (port 6543) for Railway, "Session" mode (port 5432) for direct
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DATABASE_SSL=true

# ── Supabase Storage (required for file/image uploads) ───────────────────────
# SUPABASE_URL:         Supabase dashboard → Settings → API → Project URL
# SUPABASE_SERVICE_KEY: Supabase dashboard → Settings → API → service_role key (secret)
# SUPABASE_BUCKET:      Storage bucket name (default: crm-files — only set if you renamed it)
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key...
# SUPABASE_BUCKET=crm-files

# ── Session ───────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SESSION_SECRET=change-this-to-a-long-random-string

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Email (Mailgun inbound webhook) ──────────────────────────────────────────
EMAIL_DOMAIN=mg.yourdomain.com
MAILGUN_WEBHOOK_KEY=your-mailgun-webhook-signing-key
